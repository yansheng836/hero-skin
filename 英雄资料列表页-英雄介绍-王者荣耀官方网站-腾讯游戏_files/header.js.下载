/**
 * PC端 头部导航栏
 * @author dannyyuan
 */
var pvpHeader2023 = (function () {
  var version = 'Header 版本：2025.01.08.0';
  var data = {}; // 数据
  var menuColor = '#FFFFFF'; // 一级菜单的颜色

  /**
   * 初始化
   * @param width 页面设计宽度
   * @param height 页面设计高度
   * @param scaleMode 屏幕适配方案（width：宽度适配、height：高度适配）
   */
  var init = function (width, height, scale) {
    console.log(version);
    show();
    resetSize(width, height, scale);
  };

  /**
   * 重设尺寸
   * @param width 页面设计宽度
   * @param height 页面设计高度
   * @param scaleMode 屏幕适配方案（width：宽度适配、height：高度适配）
   */
  var resetSize = function (width, height, scale) {
    data.desighWidth = width && width > 0 ? width : 1920;
    data.desighHeight = height && height > 0 ? height : 900;
    data.stageContext = new HeaderStageContext(data.desighWidth, data.desighHeight);
    data.stageContext.type = 'h';// h：横屏、v：竖屏
    data.stageContext.align = '';// 默认为"":居中,t:靠顶,l:靠左,r:靠右,b:靠底,可以结合一起用，比如tl,tr,bl,br
    data.stageContext.scaleMode = scale && scale !== '' ? scale : 'height';// width：宽度适配、height：高度适配

    onPageResize();
    window.addEventListener('resize', onPageResize);
  }

  /**
   * 改变菜单文字颜色
   * @param color 一级菜单的颜色（带#号的颜色字符串）
   */
  var changeFontColor = function (color) {
    menuColor = color;
    var menuList = document.getElementsByClassName('menu1-word-contianer-2023');
    for(var i = 0; i < menuList.length; i++) {
      menuList[i].style.color = menuColor;
    }

    if(typeof pvpLogin2023 === 'object') {
      pvpLogin2023.changeFontColor(menuColor);
    }
  };

  /**
   * 显示登录模块
   */
  var showLogin = function () {
    jsLoader('https://game.gtimg.cn/images/js/pvpcommon/pc/login.js', function () {
      pvpLogin2023.show(document.getElementById('login-2023'), function(canUseLogin) {
        pvpLogin2023.changeFontColor(menuColor);

        // 如果是旧 milo 则不支持登录
        if(canUseLogin) {
          pvpLogin2023.getLoginState(function(data){
            if(data.isLogin) {
              document.getElementById('download-button-2023').style.right = '230px';
            }
          });
        } else {
          pvpLogin2023.hide();
          console.warn('旧版 milo 不支持新版登录');
        }
      });
    });
  };

  // 显示 Header
  var show = function () {
    createCSS();
    createHTML();

    var div = document.createElement('div');
    div.setAttribute('class', 'header-container-2023');
    div.setAttribute('id', 'header-2023');
    div.innerHTML = data.headerHTML;
    var firstChild = document.body.firstChild;
    document.body.insertBefore(div, firstChild);

    // if(!isIndex()) {
    //   var list = document.querySelectorAll('.menu1-2023');
    //   for(var i = 0; i < list.length; i++) {
    //     list[i].style.width = '150px';
    //   }
    // }

    showLogin();
  };

  // 屏幕尺寸发生变化
  var onPageResize = function () {
    // console.log("onPageResize");
    // Header自适应策略：logo贴着左上角，登录贴着右上角，一级菜单居中
    var view = getViewSize();
    var showScale = view.scaleX;
    // console.log('view=', view);
    if(isIndex()) {
      document.getElementById('header-2023').style.transform = 'scale(' + showScale * uiScale() + ', ' + showScale * uiScale() + ')';
      document.getElementById('header-2023').style.left = Math.max(0, view.x) + 'px';
      document.getElementById('menu-container-2023').style.left = (data.desighWidth - 1190) / 2 + 'px';// 菜单居中
    } else {
      // 头部
      var viewWidth = Math.max(1600, data.viewWidth);// 宽度最小限制为1600
      // showScale = viewWidth / 1600;
      // console.log('uiScale=', uiScale())
      document.getElementById('header-2023').style.width = viewWidth + 'px';

      var bannerScale = Math.max(1600, data.viewWidth) / 1920;
      var bannerImage = document.getElementById('banner-image-2023');
      if(bannerImage) {
        bannerImage.style.width = 1920 * bannerScale + 'px';
        bannerImage.style.height = 360 * bannerScale + 'px';
      }
      var detailButton = document.getElementById('detail-button-2023');
      if(detailButton) {
        detailButton.style.width = 236 * bannerScale + 'px';
        detailButton.style.height = 60 * bannerScale + 'px'
        detailButton.style.left = 150 * bannerScale + 'px';
        detailButton.style.top = 340 * bannerScale + 'px';
      }

      // 菜单居中
      document.getElementById('menu-container-2023').style.left = (viewWidth - 1070) / 2 + 'px';

      // IP
      document.getElementById('ip-drawer-bg-2023').style.width = 1920 * view.scaleX * uiScale() + 'px';
      document.getElementById('ip-drawer-bg-2023').style.height = 236 + 'px';
    }

  };

